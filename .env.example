# Copy to .env, fill in real values, and never commit the populated file.
# All variables are read at backend startup time.

# ---- Runtime ----------------------------------------------------------------
# `production` switches the app into strict mode:
#   * /docs, /redoc, /openapi.json are disabled
#   * HSTS header is sent on every response
#   * uvicorn binds to 127.0.0.1 instead of 0.0.0.0
#   * a missing CLOSET_SECRET_KEY refuses to start
# Anything else (or unset) means development.
CLOSET_ENV=development

# ---- Secrets ----------------------------------------------------------------
# 48+ bytes of CSPRNG. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# In development, leave this blank and the backend will auto-generate
# backend/.secret_key the first time it boots (gitignored, dev-only).
CLOSET_SECRET_KEY=

# How long an access token stays valid (minutes). Default = 7 days.
ACCESS_TOKEN_TTL_MINUTES=10080

# ---- Network ----------------------------------------------------------------
# Comma-separated list of origins allowed to hit /api/ from a browser.
# When CLOSET_ENV != production we also auto-add the Expo dev origins.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Set to 1 only if you're behind a reverse proxy you trust (nginx, Caddy,
# Cloudflare). Otherwise leave unset — without a trusted proxy the client
# can spoof X-Forwarded-For and bypass the rate limiter.
TRUST_PROXY_HEADERS=

# ---- Upload limits ----------------------------------------------------------
# Max bytes per HTTP request and per single file inside that request.
MAX_REQUEST_BYTES=26214400
MAX_UPLOAD_BYTES=15728640

# ---- Server -----------------------------------------------------------------
HOST=
PORT=8000
UVICORN_RELOAD=1
